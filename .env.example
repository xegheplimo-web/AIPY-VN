# ===== AIPY Configuration =====
# Copy this file to .env and fill in your values
# All variables use AIPY_ prefix

# --- Server ---
AIPY_HOST=0.0.0.0
AIPY_PORT=8000
AIPY_DEBUG=false

# --- Ollama / Cloud LLM ---
AIPY_OLLAMA_URL=http://localhost:11434
AIPY_OLLAMA_API_KEY=
AIPY_OLLAMA_CLOUD_URL=https://ollama.com/api
AIPY_OLLAMA_CLOUD_API_KEY=
AIPY_OLLAMA_TIMEOUT=30000
AIPY_CLOUD_TIMEOUT_MS=8000
AIPY_DEFAULT_CHAT_MODEL=gemma4-31b
AIPY_CLOUD_MODELS=minimax-m3,kimi-k2.6,glm-5.1,qwen3.5,nemotron-3-super,gemma4-31b

# --- Database (PostgreSQL) ---
AIPY_DATABASE_URL=postgresql+asyncpg://aipy:secret@localhost:5432/aipy

# --- Redis ---
AIPY_REDIS_URL=redis://localhost:6379/0

# --- Qdrant Vector DB ---
AIPY_QDRANT_URL=http://localhost:6333
AIPY_QDRANT_API_KEY=
AIPY_QDRANT_COLLECTION=aipy_places

# --- Embedding Model ---
AIPY_EMBEDDING_MODEL=dangvantuan/vietnamese-embedding
AIPY_EMBEDDING_DIM=768

# --- Geo & Maps ---
AIPY_OVERPASS_URL=https://overpass-api.de/api/interpreter
AIPY_NOMINATIM_URL=https://nominatim.openstreetmap.org

# --- Search Defaults ---
AIPY_DEFAULT_SEARCH_RADIUS=3000
AIPY_DEFAULT_SEARCH_LIMIT=20
AIPY_CACHE_TTL_SECONDS=3600

# --- Rate Limiting ---
AIPY_RATE_LIMIT_SEARCH=10/minute
AIPY_RATE_LIMIT_NOMINATIM=1/second

# --- CORS ---
AIPY_CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# --- SerpAPI (Web Search) ---
# Get your key at https://serpapi.com/manage-api-key
# Used for high-quality web search results (Google, Bing, DuckDuckGo, etc.)
AIPY_SERPAPI_API_KEY=

# --- Security ---
# Optional API key for protecting /api/* endpoints (except health, metrics, models, suggest)
# When set, clients must send via X-API-Key header or ?api_key=... query param
AIPY_API_KEY=

# --- Search Service (Microservice) ---
# URL of the standalone search service (for microservice architecture)
# When set, backend will proxy search requests to this service
AIPY_SEARCH_SERVICE_URL=http://localhost:8001
