# Database Configuration
DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/vietstore
# Change username and password in production

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ECC Cryptography
# IMPORTANT: Generate this using the ECC service and set in production
# NEVER commit this to repository
ECC_PRIVATE_KEY_PEM=

# JWT Configuration
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:3001,http://localhost:3002

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=200
RATE_LIMIT_WINDOW_SECONDS=60

# Environment
ENVIRONMENT=development
DEBUG=true

# Logging
LOG_LEVEL=info

# OAuth Providers (Optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Payment Gateways (Optional)
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
ZALOPAY_APP_ID=
ZALOPAY_KEY1=
ZALOPAY_KEY2=

# Firebase (Optional for push notifications)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# SerpAPI (Optional for web search)
SERPAPI_KEY=
SERPAPI_ENGINE=google

# OpenMap.vn (Optional for Vietnam-specific location data)
OPENMAP_API_KEY=
OPENMAP_BASE_URL=https://api.openmap.vn/place
OPENMAP_TIMEOUT=10
