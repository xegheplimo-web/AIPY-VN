# ============================================================================
# VietStore RAG - Environment Configuration
# Auto-synced with src/config.py
# ============================================================================

# --- Core Application -------------------------------------------------------
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=info

# --- Database ---------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vietstore

# --- Redis ------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
# REDIS_ENABLED=true  # Optional: defaults to true

# --- Qdrant Vector Database -------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=vietstore_products
QDRANT_VECTOR_SIZE=384

# --- ECC Cryptography -------------------------------------------------------
# IMPORTANT: Generate this using the ECC service and set in production
# NEVER commit this to repository
ECC_PRIVATE_KEY_PEM=

# --- Ollama Cloud (AI/LLM) --------------------------------------------------
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_URL=https://api.ollama.com
OLLAMA_DEFAULT_MODEL=qwen3.5:cloud
OLLAMA_CLOUD_MODELS=minimax-m3:cloud,kimi-k2.6:cloud,glm-5.1:cloud,qwen3.5:cloud,nemotron-3-super:cloud,gemma4-31b-cloud
OLLAMA_TIMEOUT=30

# --- JWT Configuration --------------------------------------------------------
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS Origins -----------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:3001,http://localhost:3002

# --- Rate Limiting ----------------------------------------------------------
RATE_LIMIT_MAX_REQUESTS=200
RATE_LIMIT_WINDOW_SECONDS=60

# --- CSRF Protection ----------------------------------------------------------
CSRF_SECRET_KEY=

# --- Sentry Error Tracking --------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# --- Stripe Payment Processing ----------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd

# --- Firebase Push Notifications --------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=

# --- SerpAPI Web Search -----------------------------------------------------
SERPAPI_KEY=
SERPAPI_ENGINE=google
SERPAPI_TIMEOUT=10

# --- OpenMap.vn Vietnam Geo Data --------------------------------------------
OPENMAP_API_KEY=
OPENMAP_BASE_URL=https://api.openmap.vn/place
OPENMAP_TIMEOUT=10

# --- OAuth Providers (Optional) ---------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# --- Vietnam Payment Gateways (Optional) ------------------------------------
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
ZALOPAY_APP_ID=
ZALOPAY_KEY1=
ZALOPAY_KEY2=
