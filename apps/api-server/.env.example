# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vietstore

# Redis
REDIS_URL=redis://localhost:6379/0

# Qdrant
QDRANT_URL=http://localhost:6333

# Environment
ENVIRONMENT=development
DEBUG=true

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:3001,http://localhost:3002

# JWT (ECDSA)
JWT_ALGORITHM=ES256
ECC_PRIVATE_KEY_PEM=

# CSRF
CSRF_SECRET_KEY=

# Ollama Cloud (LLM)
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_URL=https://api.ollama.com
OLLAMA_DEFAULT_MODEL=qwen3.5:cloud

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=vnd

# SerpAPI
SERPAPI_KEY=

# OpenMap
OPENMAP_API_KEY=
OPENMAP_BASE_URL=https://api.openmap.vn/place

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=200
RATE_LIMIT_WINDOW_SECONDS=60

# Logging
LOG_LEVEL=info
